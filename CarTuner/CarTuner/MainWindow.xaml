<Window x:Class="CarTuner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarTuner"
        Title="CarTuner - Car Part Builder"
        Height="600" Width="950"
        Background="#FF181818">
    <Window.Resources>
        <!-- Shared button style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#FF2D89EF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#FF1B4F72"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1F5FBF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF143F80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header text -->
        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- How each part looks in the ListBox -->
        <DataTemplate x:Key="PartTemplate">
            <Border Padding="6"
                    Margin="2"
                    CornerRadius="4"
                    Background="#FF2A2A2A"
                    BorderBrush="#FF3A3A3A"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Speed: " Foreground="#FFBBBBBB"/>
                        <TextBlock Text="{Binding SpeedBonus}" Foreground="#FF76FF03"/>
                        <TextBlock Text=" +" Foreground="#FF76FF03"/>
                        <TextBlock Text="   Cost: "
                                   Margin="8,0,0,0"
                                   Foreground="#FFBBBBBB"/>
                        <TextBlock Text="{Binding Cost, StringFormat={}{0:C}}"
                                   Foreground="#FFEEEEEE"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#FF111111" Padding="10">
            <DockPanel>
                <TextBlock Text="CarTuner"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Car Part Builder"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#FFCCCCCC"/>
            </DockPanel>
        </Border>

        <!-- Tabs for navigation -->
        <TabControl x:Name="MainTabs"
                    Grid.Row="1"
                    Margin="8"
                    Background="#FF202020"
                    BorderThickness="0">

            <!-- MAIN MENU -->
            <TabItem Header="Main Menu">
                <Grid Margin="10">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="CarTuner"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,10"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Build your dream car in The Workshop, then save it to The Garage."
                                   FontSize="14"
                                   Foreground="#FFDDDDDD"
                                   Margin="0,0,0,20"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Width="420"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button Content="Go to Workshop"
                                    Width="160"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="GoToWorkshop_Click"/>
                            <Button Content="Open Garage"
                                    Width="160"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="10,0,0,0"
                                    Click="GoToGarage_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- WORKSHOP -->
            <TabItem Header="The Workshop">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: available parts + current build -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Available Parts"
                                   Style="{StaticResource SectionHeaderText}"/>

                        <ListBox x:Name="AvailablePartsListBox"
                                 Grid.Row="1"
                                 ItemsSource="{Binding AvailableParts}"
                                 ItemTemplate="{StaticResource PartTemplate}"
                                 Margin="0,5,0,5"
                                 Background="#FF202020"
                                 BorderBrush="#FF3A3A3A"
                                 Foreground="White"/>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="Add to Build"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="AddPartButton_Click"/>
                            <Button Content="Remove from Build"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="RemovePartButton_Click"/>
                        </StackPanel>

                        <GroupBox Grid.Row="3"
                                  Header="Current Build"
                                  Margin="0,5,0,0"
                                  Foreground="White"
                                  BorderBrush="#FF3A3A3A">
                            <ListBox x:Name="SelectedPartsListBox"
                                     ItemsSource="{Binding SelectedParts}"
                                     ItemTemplate="{StaticResource PartTemplate}"
                                     Margin="0,5,0,0"
                                     Background="#FF202020"
                                     BorderBrush="#FF3A3A3A"
                                     Foreground="White"/>
                        </GroupBox>
                    </Grid>

                    <!-- Center: image preview -->
                    <Grid Grid.Column="1" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Visual Preview"
                                   Style="{StaticResource SectionHeaderText}"/>

                        <Border Grid.Row="1"
                                BorderBrush="#FFCCCCCC"
                                BorderThickness="2"
                                CornerRadius="8"
                                Background="#FF1E1E1E"
                                Padding="10">
                            <Grid>
                                <Image x:Name="BuildImage"
                                       Stretch="Uniform"/>
                                <TextBlock x:Name="ImageInfoTextBlock"
                                           Text="preview."
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Opacity="0.8"/>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="2"
                                   Text="Tip: you can replace the preview images with your own car photos later."
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#FF999999"/>
                    </Grid>

                    <!-- Right: stats and save -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Build Stats"
                                   Style="{StaticResource SectionHeaderText}"/>

                        <TextBlock Text="Build Name:"
                                   Margin="0,0,0,2"
                                   Foreground="White"/>
                        <TextBox x:Name="BuildNameTextBox"
                                 Margin="0,0,0,8"
                                 Background="#FF2A2A2A"
                                 Foreground="White"
                                 BorderBrush="#FF3A3A3A"/>

                        <TextBlock Text="Current Top Speed:"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0"
                                   Foreground="White"/>
                        <TextBlock x:Name="CurrentSpeedTextBlock"
                                   FontSize="16"
                                   Margin="0,0,0,8"
                                   Foreground="#FF76FF03"/>

                        <TextBlock Text="Total Build Cost:"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0"
                                   Foreground="White"/>
                        <TextBlock x:Name="TotalCostTextBlock"
                                   FontSize="16"
                                   Margin="0,0,0,16"
                                   Foreground="#FFEEEEEE"/>

                        <Button Content="Save to Garage (JSON)"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveToGarage_Click"/>
                        <Button Content="Clear Build"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,5,0,0"
                                Click="ClearBuild_Click"/>

                        <TextBlock Text="Base top speed is 200 km/h before any parts."
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#FF999999"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- GARAGE -->
            <TabItem Header="The Garage">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Button Content="Load from Garage (JSON)"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="LoadFromGarage_Click"/>
                        <TextBlock Text="   (Shows raw JSON of a saved build.)"
                                   VerticalAlignment="Center"
                                   Foreground="#FFDDDDDD"/>
                    </StackPanel>

                    <TextBox x:Name="GarageJsonTextBox"
                             Grid.Row="1"
                             Margin="0,8,0,0"
                             Background="#FF202020"
                             Foreground="#FFEEEEEE"
                             BorderBrush="#FF3A3A3A"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>