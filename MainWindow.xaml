<Window x:Class="CarTuner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CarTuner"
        Title="CarTuner - Car Part Builder"
        Height="650" Width="1050"
        Background="#FF0F0F0F"
        FontFamily="Segoe UI">
    <Window.Resources>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="#FFD32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE53935"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFB71C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF333333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <DataTemplate x:Key="PartTemplate">
            <Border Padding="10,8" Margin="1" CornerRadius="6"
                    Background="#FF1A1A1A" BorderBrush="#FF2A2A2A" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                   FontSize="13" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="+" Foreground="#FF4CAF50" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SpeedBonus}" Foreground="#FF4CAF50" FontWeight="Bold"/>
                            <TextBlock Text=" km/h" Foreground="#FF4CAF50"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Cost, StringFormat={}{0:C}}"
                               Foreground="#FFFFB74D" FontWeight="Bold" FontSize="13"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF1A1A1A" Offset="0"/>
                    <GradientStop Color="#FF2A1A1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <TextBlock Text="🔧" FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="CAR" FontSize="24" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text="TUNER" FontSize="24" FontWeight="Bold" Foreground="#FFD32F2F"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Car Part Builder" Margin="12,0,0,0"
                           VerticalAlignment="Center" Foreground="#FF888888" FontSize="13"/>
            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="12,4,12,12"
                    Background="#FF0F0F0F" BorderThickness="0">

            <TabItem Header="Main Menu">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🔧" FontSize="48" TextAlignment="Center" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="CAR" FontSize="42" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="TUNER" FontSize="42" FontWeight="Bold" Foreground="#FFD32F2F"/>
                        </StackPanel>
                        <TextBlock Text="Build your dream car in The Workshop, then save it to The Garage."
                                   FontSize="14" Foreground="#FF999999" Margin="0,4,0,28"
                                   TextAlignment="Center" TextWrapping="Wrap" Width="400"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="🔧  Workshop" Width="160"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="GoToWorkshop_Click"/>
                            <Button Content="🏠  Garage" Width="160"
                                    Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"
                                    Click="GoToGarage_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="The Workshop">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Available Parts" Style="{StaticResource SectionHeaderText}"/>

                        <ListBox x:Name="AvailablePartsListBox" Grid.Row="1"
                                 ItemsSource="{Binding AvailableParts}"
                                 ItemTemplate="{StaticResource PartTemplate}"
                                 Background="#FF141414" BorderBrush="#FF222222" BorderThickness="1"
                                 Foreground="White"
                                 SelectionChanged="AvailablePartsListBox_SelectionChanged"/>

                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    HorizontalAlignment="Stretch" Margin="0,6,0,6">
                            <Button Content="+ Add" Style="{StaticResource PrimaryButtonStyle}"
                                    Click="AddPartButton_Click" Width="90"/>
                            <Button Content="− Remove" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="RemovePartButton_Click" Margin="6,0,0,0" Width="90"/>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Text="Current Build" Foreground="White"
                                   FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>

                        <Border Grid.Row="4" Background="#FF141414" BorderBrush="#FF222222"
                                BorderThickness="1" CornerRadius="4">
                            <ListBox x:Name="SelectedPartsListBox"
                                     ItemsSource="{Binding SelectedParts}"
                                     ItemTemplate="{StaticResource PartTemplate}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White"
                                     SelectionChanged="SelectedPartsListBox_SelectionChanged"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1" Margin="4,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Visual Preview" Style="{StaticResource SectionHeaderText}"/>

                        <Border Grid.Row="1" CornerRadius="8" Background="#FF141414"
                                BorderBrush="#FF222222" BorderThickness="1" Padding="12">
                            <Grid>
                                <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              x:Name="BuildPreviewScroll" Visibility="Collapsed">
                                    <WrapPanel x:Name="BuildPartsPanel" HorizontalAlignment="Center"/>
                                </ScrollViewer>
                                <TextBlock x:Name="ImageInfoTextBlock"
                                           Text="Click a part to preview it here."
                                           Foreground="#FF666666" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Column="2" Background="#FF141414" BorderBrush="#FF222222"
                            BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Build Stats" Style="{StaticResource SectionHeaderText}"/>

                            <TextBlock Text="BUILD NAME" Foreground="#FF888888" FontSize="10"
                                       FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox x:Name="BuildNameTextBox" Background="#FF1A1A1A"
                                     Foreground="White" BorderBrush="#FF333333"
                                     Padding="8,6" FontSize="13"/>

                            <TextBlock Text="TOP SPEED" Foreground="#FF888888" FontSize="10"
                                       FontWeight="Bold" Margin="0,16,0,4"/>
                            <TextBlock x:Name="CurrentSpeedTextBlock" FontSize="28"
                                       FontWeight="Bold" Foreground="#FF4CAF50"/>

                            <TextBlock Text="TOTAL COST" Foreground="#FF888888" FontSize="10"
                                       FontWeight="Bold" Margin="0,12,0,4"/>
                            <TextBlock x:Name="TotalCostTextBlock" FontSize="22"
                                       FontWeight="Bold" Foreground="#FFFFB74D"/>

                            <Button Content="Save to Garage" Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveToGarage_Click" Margin="0,20,0,0"
                                    HorizontalAlignment="Stretch"/>

                            <Button Content="Clear Build" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ClearBuild_Click" Margin="0,6,0,0"
                                    HorizontalAlignment="Stretch"/>

                            <CheckBox x:Name="SoundToggle" Content="Sound On" IsChecked="True"
                                      Margin="2,12,0,0" Foreground="#FF888888" FontSize="12"
                                      Checked="SoundToggle_Changed" Unchecked="SoundToggle_Changed"/>

                            <TextBlock Text="Base speed: 230 km/h" Margin="0,16,0,0"
                                       Foreground="#FF444444" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="The Garage">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Load Build" Style="{StaticResource PrimaryButtonStyle}"
                                Click="LoadFromGarage_Click"/>
                        <TextBlock Text="Load a saved build to view its details."
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="#FF888888" FontSize="13"/>
                    </StackPanel>

                    <Border Grid.Row="1" Margin="0,8,0,0" Background="#FF141414"
                            BorderBrush="#FF222222" BorderThickness="1" CornerRadius="6"
                            Padding="12">
                        <TextBox x:Name="GarageJsonTextBox" Background="Transparent"
                                 Foreground="#FF4FC3F7" BorderThickness="0"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto" IsReadOnly="True"
                                 TextWrapping="Wrap" FontFamily="Consolas" FontSize="13"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>